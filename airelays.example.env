# AIRelays environment override example

AIRELAYS_PORT=8080
AIRELAYS_AUTH_STORAGE=auto
AIRELAYS_BROWSER_OPEN=false
AIRELAYS_REQUIRE_BEARER_AUTH=true
AIRELAYS_DATA_DIR=~/.airelays
AIRELAYS_LOGS_DIR=~/.airelays/logs
AIRELAYS_BEARER_TOKEN_FILE=~/.airelays/relay-token
AIRELAYS_AUTO_GENERATE_BEARER_TOKEN=false
AIRELAYS_MAX_UPLOAD_BYTES=33554432
AIRELAYS_MAX_TOTAL_UPLOAD_BYTES=268435456

AIRELAYS_ENABLE_OPENAI=true
AIRELAYS_ENABLE_CLAUDE_EXPERIMENTAL=false
AIRELAYS_CLAUDE_BIN=claude
AIRELAYS_CLAUDE_TIMEOUT_SECONDS=600
AIRELAYS_CLAUDE_MAX_CONCURRENT_REQUESTS=2
AIRELAYS_CLAUDE_STRIP_API_KEY_ENV=true
AIRELAYS_CLAUDE_MODELS=claude:sonnet,claude:opus,claude:haiku,claude:fable
